# ================================================
# ReconCrew v4 — Configuration
# ================================================

# --- Target ---
TARGET_URL=https://target.example.com
MAX_PAGES=100
MAX_DEPTH=5

# --- LLM: openai | lmstudio | anthropic ---
LLM_PROVIDER=openai
MODEL_NAME=gpt-5.4-mini
OPENAI_API_KEY=sk-proj-...
OPENAI_BASE_URL=https://api.openai.com/v1

# --- LM Studio (Windows host desde WSL2/Docker) ---
LM_STUDIO_URL=http://192.168.1.1:1234/v1
LM_STUDIO_MODEL=qwen2.5-14b-instruct

# --- Anthropic (opcional) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Auth ---
AUTH_ENABLED=false
AUTH_TYPE=form           # form | cookie | bearer
AUTH_URL=https://target.example.com/login
AUTH_USERNAME=admin
AUTH_PASSWORD=s3cr3t
AUTH_USERNAME_FIELD=username
AUTH_PASSWORD_FIELD=password
AUTH_COOKIES={"session_id":"abc123","csrf":"xyz"}
AUTH_BEARER_TOKEN=eyJhbGciOiJIUzI1NiJ9...

# --- Playwright ---
HEADLESS=true
BROWSER_TIMEOUT=30000
WAIT_AFTER_LOAD_MS=1500

# --- Output ---
REPORT_DIR=/app/reports
LOG_LEVEL=INFO